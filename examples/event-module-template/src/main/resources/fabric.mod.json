{
  "schemaVersion": 1,
  "id": "meumod",
  "version": "${version}",
  "name": "Meu Mod de Evento",
  "description": "Adiciona um novo tipo de evento ao BigBangEventos.",
  "authors": ["Voce"],
  "contact": {},
  "license": "MIT",
  "environment": "server",
  "entrypoints": {
    "main": [
      "com.meumod.MeuModInitializer"
