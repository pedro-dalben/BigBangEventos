  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "1.21.1",
    "java": ">=21",
    "fabric-api": ">=0.116.13+1.21.1",
    "bigbangeventos": ">=0.1.0"
  },
  "custom": {
    "bigbangeventos:module": {
      "id": "meumod",
      "api-version": 1
    }
  }
